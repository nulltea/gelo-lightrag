# Per-host runner environment.
#
# SNP_MODE must be one of `production` (real /dev/sev-guest) or `mock`
# (bundled test PKI). The runner refuses to start if unset — there is no
# autodetection. Override per deployment tier:
#   T2 (regular QEMU guest): SNP_MODE=mock
#   T3 (real EPYC CVM):      SNP_MODE=production
SNP_MODE=mock

# Optional: HuggingFace model coordinate + revision. Used by
# gelo-fetch-weights to populate /var/lib/gelo-snp/weights on first boot.
GELO_MODEL_REPO=Qwen/Qwen3-Embedding-0.6B
GELO_MODEL_REVISION=main

# Optional: expected SHA-256 of the concatenated safetensors shards.
# Mismatch ⇒ gelo-fetch-weights.service fails ⇒ gelo-snp-runner.service
# does not start.
GELO_WEIGHTS_SHA256=
