# Attack-bench + GELO environment for the persistent-attention security
# gates (docs/plans/perm-attn-gpu-offload.md). Runs the Python AloePri
# attack harness (numpy/scipy/sklearn/torch — reference-free HNM + JADE/
# anchor_ica) and, with the repo mounted, builds/runs GELO (Cargo).
#
# Build:  podman build -t gelo-attack -f evals/aloepri-attacks/Containerfile .
# Run:    evals/aloepri-attacks/run-in-container.sh <cmd...>
#
# The base image (cuda 12.9.2 cudnn-devel, ubuntu 24.04) matches the host
# CUDA toolkit so the `cuda` engine feature builds in-container too. GPU
# passthrough is via CDI (`--device nvidia.com/gpu=all`); the attack
# harness itself is CPU-only (ICA/JADE need no GPU).
FROM docker.io/nvidia/cuda:12.9.2-cudnn-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

# System deps: python, build toolchain, git/curl for rustup.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        build-essential pkg-config git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Python attack-harness deps. Ubuntu 24.04 is PEP-668 externally-managed;
# --break-system-packages is fine in a throwaway container. torch is the
# CPU wheel (the attacks don't need the GPU; keeps the layer ~200 MB).
RUN python3 -m pip install --break-system-packages --no-cache-dir \
        numpy scipy scikit-learn safetensors transformers tokenizers pytest \
    && python3 -m pip install --break-system-packages --no-cache-dir \
        torch --index-url https://download.pytorch.org/whl/cpu

# Rust toolchain for building/running GELO in-container (BLIS comes from
# the mounted repo's vendor/aocl-install — same linux/amd64 arch).
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /work
