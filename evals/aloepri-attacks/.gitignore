__pycache__/

# Captured PCIe-side / wire-side observables. Often multi-GB
# (qwen3-1.7b-rg64 c2_default = 6 GB). Result JSONs in results/
# are the small, version-controllable summaries; snapshots/ is
# the raw artifact those summaries are derived from.
snapshots/
# results/ is ignored at the file level so large captured JSONs
# (hidden-state dumps, token streams) don't get tracked, but
# the small per-cell sweep summaries under results/sweep/ are
# evidence we want to version.
results/*
!results/sweep/
# Raw server tensor-dump binary files (intermediate; the per-prompt
# safetensors next to them is the canonical derived artifact).
results/sweep/**/*.bin
