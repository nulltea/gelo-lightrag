From ae0cadc58ce6a0a548398ba3b2988e18ade67ae6 Mon Sep 17 00:00:00 2001
From: Timo <timofey@chainsafe.io>
Date: Tue, 19 May 2026 12:03:53 +0200
Subject: [PATCH] M2.7: tensor-dump hook for llama-server
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Adds two CLI flags driving the existing common_debug_cb_eval
infrastructure to write captured tensors to a binary file per
forward pass.

  --tensor-filter REGEX    (existing; extended to LLAMA_EXAMPLE_SERVER)
  --tensor-dump-path FILE  (new — file written from inside ggml callback)

Record format:
  u32 name_len + name + i64[4] ne + u8 dtype + u64 n_bytes + raw

Auto-wires the callback in common_init_from_params when --tensor-filter
is set and no explicit cb_eval was supplied.

~80 lines, 5 files in common/. Same eval-callback infrastructure the
existing llama-debug tool uses.
---
 common/arg.cpp    | 12 +++++++++++-
 common/common.cpp | 28 ++++++++++++++++++++++++++--
 common/common.h   |  1 +
 common/debug.cpp  | 29 +++++++++++++++++++++++++++++
 common/debug.h    | 13 +++++++++++++
 5 files changed, 80 insertions(+), 3 deletions(-)

diff --git a/common/arg.cpp b/common/arg.cpp
index d7a935f..eeba67e 100644
--- a/common/arg.cpp
+++ b/common/arg.cpp
@@ -3937,7 +3937,17 @@ common_params_context common_params_parser_init(common_params & params, llama_ex
         [](common_params & params, const std::string & value) {
             params.tensor_filter.push_back(value);
         }
-    ).set_examples({LLAMA_EXAMPLE_DEBUG}));
+    ).set_examples({LLAMA_EXAMPLE_DEBUG, LLAMA_EXAMPLE_SERVER}));
+    add_opt(common_arg(
+        {"--tensor-dump-path"}, "FILE",
+        "M2.7: write captured (filtered) tensors to FILE in binary form. "
+        "Each tensor record: u32 name_len + name + i64[4] ne + u8 dtype + u64 n_bytes + raw data. "
+        "File is opened in append mode; the operator truncates before each forward pass to delimit. "
+        "Requires --tensor-filter to be set; pair with --no-flash-attn to capture Q·Kᵀ ('kq-*').",
+        [](common_params & params, const std::string & value) {
+            params.tensor_dump_path = value;
+        }
+    ).set_examples({LLAMA_EXAMPLE_DEBUG, LLAMA_EXAMPLE_SERVER}));
 
     // presets
     add_opt(common_arg(
diff --git a/common/common.cpp b/common/common.cpp
index 9cf11ea..d54821e 100644
--- a/common/common.cpp
+++ b/common/common.cpp
@@ -3,6 +3,7 @@
 
 #include "build-info.h"
 #include "common.h"
+#include "debug.h"
 #include "fit.h"
 #include "log.h"
 #include "llama.h"
@@ -1574,8 +1575,31 @@ struct llama_context_params common_context_params_to_llama(const common_params &
     cparams.pooling_type      = params.pooling_type;
     cparams.attention_type    = params.attention_type;
     cparams.flash_attn_type   = params.flash_attn_type;
-    cparams.cb_eval           = params.cb_eval;
-    cparams.cb_eval_user_data = params.cb_eval_user_data;
+    // M2.7 — auto-wire the debug callback when --tensor-filter is set
+    // and no explicit cb_eval was supplied. The holder is static so
+    // it outlives the llama_context; single-init across all contexts
+    // in the process (single-slot server invariant).
+    static std::unique_ptr<common_debug_cb_user_data> m2_7_debug_holder;
+    if (!params.tensor_filter.empty() && params.cb_eval == nullptr && !m2_7_debug_holder) {
+        // The constructor expects a mutable common_params (it writes
+        // cb_eval back into it). We don't care about those writes —
+        // we'll assign cparams.cb_eval directly below — so use a
+        // throwaway local. Avoids const_cast on the caller's params.
+        common_params throwaway;
+        m2_7_debug_holder = std::make_unique<common_debug_cb_user_data>(
+            throwaway, params.tensor_filter, /*abort_on_nan=*/false);
+        if (!params.tensor_dump_path.empty()) {
+            m2_7_debug_holder->set_dump_path(params.tensor_dump_path);
+        }
+    }
+
+    if (m2_7_debug_holder && params.cb_eval == nullptr) {
+        cparams.cb_eval           = common_debug_cb_eval;
+        cparams.cb_eval_user_data = m2_7_debug_holder.get();
+    } else {
+        cparams.cb_eval           = params.cb_eval;
+        cparams.cb_eval_user_data = params.cb_eval_user_data;
+    }
     cparams.offload_kqv       = !params.no_kv_offload;
     cparams.no_perf           = params.no_perf;
     cparams.op_offload        = !params.no_op_offload;
diff --git a/common/common.h b/common/common.h
index 1d3d788..01d9183 100644
--- a/common/common.h
+++ b/common/common.h
@@ -490,6 +490,7 @@ struct common_params {
     std::string logits_output_dir = "data"; // directory for saving logits output files                     // NOLINT
     bool        save_logits       = false;  // whether to save logits to files                              // NOLINT
     std::vector<std::string> tensor_filter; // filter tensor names for debug output (regex)                 // NOLINT
+    std::string tensor_dump_path;            // M2.7: binary tensor dump output path (server mode)         // NOLINT
 
     std::vector<std::string> in_files;   // all input files
     std::vector<std::string> antiprompt; // strings upon which more user input is prompted (a.k.a. reverse prompts)
diff --git a/common/debug.cpp b/common/debug.cpp
index 102c692..fda31f3 100644
--- a/common/debug.cpp
+++ b/common/debug.cpp
@@ -4,6 +4,8 @@
 #include "log.h"
 
 #include <cmath>
+#include <cstdio>
+#include <cstring>
 #include <regex>
 #include <string>
 #include <vector>
@@ -12,11 +14,16 @@ struct common_debug_cb_user_data::impl {
     std::vector<uint8_t>    data;
     std::vector<std::regex> tensor_filters;
     bool                    abort_on_nan{false};
+    std::string             dump_path; // M2.7 binary dump output (empty = disabled)
 };
 
 common_debug_cb_user_data::common_debug_cb_user_data() : pimpl(std::make_unique<impl>()) {}
 common_debug_cb_user_data::~common_debug_cb_user_data() = default;
 
+void common_debug_cb_user_data::set_dump_path(const std::string & path) {
+    pimpl->dump_path = path;
+}
+
 common_debug_cb_user_data::common_debug_cb_user_data(common_params & params, const std::vector<std::string> & filter_patterns, bool abort_on_nan)
     : pimpl(std::make_unique<impl>())
 {
@@ -186,5 +193,27 @@ bool common_debug_cb_eval(struct ggml_tensor * t, bool ask, void * user_data) {
         common_debug_print_tensor(data, t->type, t->ne, t->nb, 3, pimpl->abort_on_nan);
     }
 
+    // M2.7 binary dump path — append-only. Python harness truncates
+    // the file before each request to delimit forward passes.
+    if (matches_filter && !pimpl->dump_path.empty() && !ggml_is_quantized(t->type)) {
+        FILE * f = std::fopen(pimpl->dump_path.c_str(), "ab");
+        if (f) {
+            const uint8_t * data = is_host ? (const uint8_t *) t->data : pimpl->data.data();
+            const uint32_t name_len = (uint32_t) std::strlen(t->name);
+            std::fwrite(&name_len, sizeof(name_len), 1, f);
+            std::fwrite(t->name, 1, name_len, f);
+            const int64_t shape[4] = { t->ne[0], t->ne[1], t->ne[2], t->ne[3] };
+            std::fwrite(shape, sizeof(shape[0]), 4, f);
+            const uint8_t dtype = (uint8_t) t->type;
+            std::fwrite(&dtype, sizeof(dtype), 1, f);
+            const uint64_t n_bytes = (uint64_t) ggml_nbytes(t);
+            std::fwrite(&n_bytes, sizeof(n_bytes), 1, f);
+            std::fwrite(data, 1, (size_t) n_bytes, f);
+            std::fclose(f);
+        } else {
+            LOG("%s: WARN — failed to open dump path %s\n", __func__, pimpl->dump_path.c_str());
+        }
+    }
+
     return true;
 }
diff --git a/common/debug.h b/common/debug.h
index 8b8f8c7..5d5a50e 100644
--- a/common/debug.h
+++ b/common/debug.h
@@ -28,4 +28,17 @@ struct common_debug_cb_user_data {
     common_debug_cb_user_data & operator=(const common_debug_cb_user_data &) = delete;
 
     common_debug_cb_user_data(common_params & params, const std::vector<std::string> & filter_patterns, bool abort_on_nan = false);
+
+    // M2.7 — when set, every tensor that passes `filter_patterns` is
+    // appended to a binary file at `path`. Each tensor record:
+    //   uint32_le  name_len
+    //   char[name_len]      tensor name (no null terminator)
+    //   int64_le[4]         ne (ggml shape, fastest-varying first)
+    //   uint8              ggml_type (0=f32, 1=f16, …)
+    //   uint64_le          n_bytes
+    //   char[n_bytes]      raw tensor data (host-converted)
+    // File is opened in append mode. The single-slot server protocol
+    // is: Python harness truncates the file before each request, server
+    // appends one forward-pass worth of tensors, Python reads.
+    void set_dump_path(const std::string & path);
 };
-- 
