# evals/aloepri-attacks/m2_7/patches/, applied via apply-patches.sh.
vendor/aloepri-py/
# AloePri-attacks captures (per-run, multi-GB)
snapshots/
# Python virtualenvs (one per pip-installed path)
python/*/.venv/
python/*/__pycache__/
**/__pycache__/
*.pyc
