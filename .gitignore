.claude
target/
Cargo.lock
.fastembed_cache/
crates/*/.fastembed_cache/
# AOCL-BLIS source + install (built by scripts/install-aocl-blis.sh)
vendor/aocl-blis/
vendor/aocl-install/
# Path-2 AloePri vendored deps + build artifacts
# vendor/llama.cpp is a git submodule pinned at upstream master.
